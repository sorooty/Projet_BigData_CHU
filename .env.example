# Copie ce fichier en .env pour ton poste local.
# On met ici uniquement des valeurs d'exemple, jamais de vrais secrets.
POSTGRES_DB=chu_data
POSTGRES_USER=chu_admin
POSTGRES_PASSWORD=chu_password_change_me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Schémas standards du projet.
POSTGRES_SCHEMA_BRONZE=bronze
POSTGRES_SCHEMA_SILVER=silver
POSTGRES_SCHEMA_GOLD=gold
# Clé utilisée pour pseudonymiser les identifiants sensibles.
PSEUDONYMIZATION_KEY=change_me_32_chars_minimum
