# Copie ce fichier vers .env avant de lancer docker-compose up -d.
# Ne jamais committer le fichier .env (il est dans .gitignore).

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=chu_data
POSTGRES_USER=chu_admin
POSTGRES_PASSWORD=chu_password_change_me11
POSTGRES_PORT=5432

# POSTGRES_HOST=postgres  → depuis les containers Airflow (réseau Docker interne)
# POSTGRES_HOST=localhost  → depuis PowerBI ou scripts locaux hors Docker
POSTGRES_HOST=postgres
POSTGRES_SOURCE_DB=postgres
POSTGRES_SOURCE_TABLE=operational.consultation
# Optionnel: filtre SQL pour un extract incrémental
# POSTGRES_SOURCE_FILTER=date_consultation >= CURRENT_DATE - INTERVAL '1 day'

# Base dédiée aux métadonnées Airflow (séparée de chu_data)
AIRFLOW_DB=airflow

# ── Airflow ─────────────────────────────────────────────────────────────────
# UID utilisateur Airflow dans le container (50000 = défaut image officielle)
AIRFLOW_UID=50000
AIRFLOW_DATA_DIR=/opt/airflow/data

# Clé de chiffrement des connexions Airflow.
# Générer avec: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=CHANGE_ME_generate_with_command_above

# Identifiants de l'interface Airflow (http://localhost:8080)
AIRFLOW_ADMIN_USER=airflow
AIRFLOW_ADMIN_PASSWORD=airflow

# ── RGPD ─────────────────────────────────────────────────────────────────────
# Clé de pseudonymisation des identifiants sensibles (patients, professionnels)
PSEUDONYMIZATION_KEY=change_me_32_chars_minimum_secret

# ── FTP (optionnel) ───────────────────────────────────────────────────────────
# Desactive par defaut. Activer uniquement si la source FTP est disponible.
FTP_ENABLED=false
FTP_USE_TLS=false
FTP_HOST=
FTP_PORT=21
FTP_USER=
FTP_PASSWORD=
FTP_REMOTE_DIR=/
FTP_FILE_PATTERN=*.csv
FTP_TIMEOUT=60
